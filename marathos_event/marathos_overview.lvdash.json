{
  "datasets": [
    {
      "name": "ds_kpis",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT COUNT(*) AS total_finishes,        COUNT(DISTINCT result_id) AS distinct_results FROM marathos.gold.fct_results"
      ]
    },
    {
      "name": "ds_finishes_per_year",
      "displayName": "Finishes per year",
      "queryLines": [
        "SELECT event_year, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched GROUP BY event_year ORDER BY event_year"
      ]
    },
    {
      "name": "ds_top_events",
      "displayName": "Top 15 events by participation",
      "queryLines": [
        "SELECT event_name, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched GROUP BY event_name ORDER BY n_finishes DESC LIMIT 15"
      ]
    },
    {
      "name": "ds_top_countries",
      "displayName": "Top 25 countries",
      "queryLines": [
        "SELECT COALESCE(c.country_name, r.athlete_country) AS country, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched r LEFT JOIN marathos.gold.dim_country c ON r.athlete_country = c.country_code GROUP BY country ORDER BY n_finishes DESC LIMIT 25"
      ]
    },
    {
      "name": "ds_age_dist",
      "displayName": "Athlete age distribution",
      "queryLines": [
        "SELECT FLOOR(athlete_age / 5) * 5 AS age_bucket, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched WHERE athlete_age BETWEEN 10 AND 100 GROUP BY age_bucket ORDER BY age_bucket"
      ]
    },
    {
      "name": "ds_avg_speed_by_year",
      "displayName": "Avg speed (km/h) by year — distance events",
      "queryLines": [
        "SELECT event_year, AVG(athlete_average_speed) AS avg_speed_kmh FROM marathos.gold.vw_results_enriched WHERE event_type = 'distance' GROUP BY event_year ORDER BY event_year"
      ]
    }
  ],
