{
  "datasets": [
    {
      "name": "ds_a1",
      "displayName": "A1 Total finishes",
      "queryLines": [
        "SELECT COUNT(*) AS total_finishes FROM marathos.gold.fct_results"
      ]
    },
    {
      "name": "ds_a2",
      "displayName": "A2 Distinct athletes",
      "queryLines": [
        "SELECT COUNT(*) AS distinct_athletes FROM marathos.gold.dim_athlete"
      ]
    },
    {
      "name": "ds_a3",
      "displayName": "A3 Distinct events",
      "queryLines": [
        "SELECT COUNT(*) AS distinct_events FROM marathos.gold.dim_event"
      ]
    },
    {
      "name": "ds_a4",
      "displayName": "A4 Countries represented",
      "queryLines": [
        "SELECT COUNT(DISTINCT athlete_country) AS countries_represented FROM marathos.gold.dim_athlete WHERE athlete_country IS NOT NULL"
      ]
    },
    {
      "name": "ds_a5",
      "displayName": "A5 Median 100km finish hours",
      "queryLines": [
        "SELECT ROUND(PERCENTILE_APPROX(performance_time_seconds, 0.5) / 3600.0, 2) AS median_100k_finish_hours FROM marathos.gold.vw_results_enriched WHERE event_type = 'distance' AND event_distance_km BETWEEN 99 AND 101 AND performance_time_seconds IS NOT NULL"
      ]
    },
    {
      "name": "ds_a6",
      "displayName": "A6 Female participation %",
      "queryLines": [
        "SELECT ROUND(100.0 * SUM(CASE WHEN athlete_gender = 'W' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS female_participation_pct FROM marathos.gold.vw_results_enriched WHERE athlete_gender IN ('M','W')"
      ]
    },
    {
      "name": "ds_b1",
      "displayName": "B1 Finishes per year",
      "queryLines": [
        "SELECT event_year, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched GROUP BY event_year ORDER BY event_year"
      ]
    },
    {
      "name": "ds_b2",
      "displayName": "B2 YoY growth %",
      "queryLines": [
        "WITH yearly AS (SELECT event_year, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched GROUP BY event_year) SELECT event_year, ROUND(100.0 * (n_finishes - LAG(n_finishes) OVER (ORDER BY event_year)) / NULLIF(LAG(n_finishes) OVER (ORDER BY event_year), 0), 1) AS yoy_growth_pct FROM yearly ORDER BY event_year"
      ]
    },
    {
      "name": "ds_b3",
      "displayName": "B3 Cumulative athletes",
      "queryLines": [
        "WITH athlete_debut AS (SELECT f.athlete_id, MIN(d.year) AS first_year FROM marathos.gold.fct_results f JOIN marathos.gold.dim_date d USING (date_id) GROUP BY f.athlete_id) SELECT first_year AS event_year, COUNT(*) AS new_athletes, SUM(COUNT(*)) OVER (ORDER BY first_year) AS cumulative_athletes FROM athlete_debut WHERE first_year IS NOT NULL GROUP BY first_year ORDER BY first_year"
      ]
    },
    {
      "name": "ds_b4",
      "displayName": "B4 Top 15 events",
      "queryLines": [
        "SELECT event_name, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched GROUP BY event_name ORDER BY n_finishes DESC LIMIT 15"
      ]
    },
    {
      "name": "ds_c1",
      "displayName": "C1 Top 25 countries",
      "queryLines": [
        "SELECT COALESCE(c.country_name, r.athlete_country) AS country, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched r LEFT JOIN marathos.gold.dim_country c ON r.athlete_country = c.country_code WHERE r.athlete_country IS NOT NULL GROUP BY country ORDER BY n_finishes DESC LIMIT 25"
      ]
    },
    {
      "name": "ds_c2",
      "displayName": "C2 Country diversity per year",
      "queryLines": [
        "SELECT event_year, COUNT(DISTINCT athlete_country) AS countries_represented FROM marathos.gold.vw_results_enriched WHERE athlete_country IS NOT NULL GROUP BY event_year ORDER BY event_year"
      ]
    },
    {
      "name": "ds_c3",
      "displayName": "C3 Fastest 100km nations",
      "queryLines": [
        "SELECT COALESCE(c.country_name, r.athlete_country) AS country, COUNT(*) AS n_finishes, ROUND(AVG(r.performance_time_seconds) / 3600.0, 2) AS avg_finish_hours, ROUND(MIN(r.performance_time_seconds) / 3600.0, 2) AS fastest_finish_hours FROM marathos.gold.vw_results_enriched r LEFT JOIN marathos.gold.dim_country c ON r.athlete_country = c.country_code WHERE r.event_distance_km BETWEEN 99 AND 101 AND r.performance_time_seconds IS NOT NULL AND r.athlete_country IS NOT NULL GROUP BY country HAVING COUNT(*) >= 50 ORDER BY avg_finish_hours ASC LIMIT 25"
      ]
    },
    {
      "name": "ds_d1",
      "displayName": "D1 Age distribution",
      "queryLines": [
        "SELECT FLOOR(athlete_age / 5) * 5 AS age_bucket, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched WHERE athlete_age BETWEEN 18 AND 80 GROUP BY age_bucket ORDER BY age_bucket"
      ]
    },
    {
      "name": "ds_d2",
      "displayName": "D2 Gender by decade",
      "queryLines": [
        "SELECT FLOOR(event_year / 10) * 10 AS decade, athlete_gender, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched WHERE athlete_gender IN ('M','W') AND event_year IS NOT NULL GROUP BY decade, athlete_gender ORDER BY decade, athlete_gender"
      ]
    },
    {
      "name": "ds_d3",
      "displayName": "D3 Average finisher age",
      "queryLines": [
        "SELECT event_year, ROUND(AVG(athlete_age), 1) AS avg_finisher_age FROM marathos.gold.vw_results_enriched WHERE athlete_age BETWEEN 18 AND 80 GROUP BY event_year ORDER BY event_year"
      ]
    },
    {
      "name": "ds_e1",
      "displayName": "E1 Distance-band mix",
      "queryLines": [
        "SELECT CASE WHEN event_distance_km < 60 THEN '50-59 km' WHEN event_distance_km < 110 THEN '60-109 km' WHEN event_distance_km < 170 THEN '110-169 km' ELSE '170+ km' END AS distance_band, COUNT(*) AS n_finishes FROM marathos.gold.vw_results_enriched WHERE event_type = 'distance' AND event_distance_km IS NOT NULL GROUP BY distance_band ORDER BY n_finishes DESC"
      ]
    },
    {
      "name": "ds_e2",
      "displayName": "E2 Avg speed by band",
      "queryLines": [
        "SELECT CASE WHEN event_distance_km < 60 THEN '50-59 km' WHEN event_distance_km < 110 THEN '60-109 km' WHEN event_distance_km < 170 THEN '110-169 km' ELSE '170+ km' END AS distance_band, ROUND(AVG(athlete_average_speed), 2) AS avg_speed_kmh FROM marathos.gold.vw_results_enriched WHERE event_type = 'distance' AND event_distance_km IS NOT NULL AND athlete_average_speed IS NOT NULL GROUP BY distance_band ORDER BY avg_speed_kmh DESC"
      ]
    },
    {
      "name": "ds_e3",
      "displayName": "E3 Avg speed per year",
      "queryLines": [
        "SELECT event_year, ROUND(AVG(athlete_average_speed), 3) AS avg_speed_kmh FROM marathos.gold.vw_results_enriched WHERE event_type = 'distance' AND athlete_average_speed IS NOT NULL GROUP BY event_year ORDER BY event_year"
      ]
    },
    {
      "name": "ds_e4",
      "displayName": "E4 24h avg distance per year",
      "queryLines": [
        "SELECT event_year, ROUND(AVG(performance_distance_km), 2) AS avg_distance_km FROM marathos.gold.vw_results_enriched WHERE event_distance_length = '24h' AND performance_distance_km IS NOT NULL GROUP BY event_year ORDER BY event_year"
      ]
    },
    {
      "name": "ds_f1",
      "displayName": "F1 Top 10 fastest 100km",
      "queryLines": [
        "SELECT r.event_name, r.event_year, COALESCE(c.country_name, r.athlete_country) AS country, r.athlete_gender, r.athlete_age, ROUND(r.performance_time_seconds / 3600.0, 2) AS finish_hours FROM marathos.gold.vw_results_enriched r LEFT JOIN marathos.gold.dim_country c ON r.athlete_country = c.country_code WHERE r.event_distance_km BETWEEN 99 AND 101 AND r.performance_time_seconds IS NOT NULL ORDER BY r.performance_time_seconds ASC LIMIT 10"
      ]
    },
    {
      "name": "ds_f2",
      "displayName": "F2 Top 10 longest 24h",
      "queryLines": [
        "SELECT r.event_name, r.event_year, COALESCE(c.country_name, r.athlete_country) AS country, r.athlete_gender, r.athlete_age, ROUND(r.performance_distance_km, 2) AS distance_km FROM marathos.gold.vw_results_enriched r LEFT JOIN marathos.gold.dim_country c ON r.athlete_country = c.country_code WHERE r.event_distance_length = '24h' AND r.performance_distance_km IS NOT NULL ORDER BY r.performance_distance_km DESC LIMIT 10"
      ]
    },
    {
      "name": "ds_f3",
      "displayName": "F3 100km record progression",
      "queryLines": [
        "WITH yearly_best AS (SELECT event_year, MIN(performance_time_seconds)/3600.0 AS year_best_hours FROM marathos.gold.vw_results_enriched WHERE event_distance_km BETWEEN 99 AND 101 AND performance_time_seconds IS NOT NULL GROUP BY event_year) SELECT event_year, ROUND(MIN(year_best_hours) OVER (ORDER BY event_year), 2) AS world_record_to_date FROM yearly_best ORDER BY event_year"
      ]
    },
    {
      "name": "ds_f4",
      "displayName": "F4 Gender speed gap by decade",
      "queryLines": [
        "SELECT FLOOR(event_year/10)*10 AS decade, athlete_gender, ROUND(AVG(athlete_average_speed), 3) AS avg_speed_kmh FROM marathos.gold.vw_results_enriched WHERE event_type='distance' AND athlete_gender IN ('M','W') AND athlete_average_speed IS NOT NULL AND event_year IS NOT NULL GROUP BY decade, athlete_gender ORDER BY decade, athlete_gender"
      ]
    },
    {
      "name": "ds_g1",
      "displayName": "G1 Bronze source counts",
      "queryLines": [
        "SELECT CASE WHEN source_file LIKE '%historical%' THEN 'historical' WHEN source_file LIKE '%simulated%' THEN 'simulated' ELSE 'unknown' END AS source, COUNT(*) AS rows_in_bronze FROM marathos.bronze.races_raw GROUP BY source ORDER BY rows_in_bronze DESC"
      ]
    },
    {
      "name": "ds_g2",
      "displayName": "G2 Most recent events",
      "queryLines": [
        "SELECT e.event_name, d.full_date AS event_date, COUNT(*) AS n_finishers, ROUND(AVG(f.athlete_average_speed), 2) AS avg_speed_kmh FROM marathos.gold.fct_results f JOIN marathos.gold.dim_event e USING (event_id) JOIN marathos.gold.dim_date d USING (date_id) GROUP BY e.event_name, d.full_date ORDER BY d.full_date DESC LIMIT 10"
      ]
    }
  ],
